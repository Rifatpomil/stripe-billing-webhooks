# Database (default works with docker-compose postgres)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/billing

# Stripe - get from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SECRET_KEY=sk_test_...

# Optional: for checkout session creation
STRIPE_API_VERSION=2024-11-20.acacia

# Webhook retry
WEBHOOK_RETRY_MAX_ATTEMPTS=5
WEBHOOK_RETRY_DELAY_SECONDS=60
WEBHOOK_RETRY_WORKER_ENABLED=true
WEBHOOK_RETRY_WORKER_INTERVAL_SECONDS=60
